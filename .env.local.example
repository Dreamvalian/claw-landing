# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
DEPLOY_WEBHOOK_SECRET=your_webhook_secret_here

# Optional AI Provider
ANTHROPIC_API_KEY=
